# Frontend
VITE_API_URL=/api

# Backend public URL
PUBLIC_APP_URL=http://localhost:8000

# Persistent storage
# If DATABASE_URL is set, app state/users/sessions/attachment metadata will use Postgres.
DATABASE_URL=
# DATA_DIR is still used for physical uploaded files unless you later move file storage to S3 or similar.
DATA_DIR=backend/storage

# AI provider
# Use auto to prefer OpenAI when configured, then Anthropic, then fallback rule-based summaries.
AI_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Portal verification
PORTAL_PROVIDER=official-portal-automation
PORTAL_API_BASE_URL=
PORTAL_API_TOKEN=
PORTAL_LIVE_CHECKS=1
UK_MCA_COC_PORTAL_URL=https://coccec.mcga.gov.uk/
DG_SHIPPING_PORTAL_URL=https://www.dgshipping.gov.in/
DG_SHIPPING_CDC_CHECKER_URL=http://220.156.189.33/IndosApplication/Indos/CDCChecker.jsp
DG_SHIPPING_COC_CHECKER_URL=http://220.156.189.33/esamudraUI/jsp/examination/checker/COCSearch.jsp?hidProcessId=COC
DG_SHIPPING_INDOS_CHECKER_URL=http://220.156.189.33/esamudraUI/jsp/examination/checker/PP_IndosChecker.jsp
IMO_GISIS_CERTIFICATE_DIRECTORY_URL=https://gisis.imo.org/Public/CP/Browse.aspx?List=CV9&Function=2%20IMO%20Web%20Accounts
IMO_GISIS_USERNAME=
IMO_GISIS_PASSWORD=

# Crewlink import
CREWLINK_API_BASE_URL=https://api.crewlinkasm.com/api
CREWLINK_WEB_BASE_URL=https://www.crewlinkasm.com
CREWLINK_API_TOKEN=
CREWLINK_VESSEL_ID=
