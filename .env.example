# Frontend
VITE_API_URL=/api

# Backend public URL
PUBLIC_APP_URL=http://localhost:8000

# Persistent storage
# Point this to a mounted Railway volume or other durable path in production.
DATA_DIR=backend/storage

# AI provider
# Use auto to prefer OpenAI when configured, then Anthropic, then fallback rule-based summaries.
AI_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Portal verification
PORTAL_PROVIDER=mock
PORTAL_API_BASE_URL=
PORTAL_API_TOKEN=
